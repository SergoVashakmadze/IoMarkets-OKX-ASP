# ── IoMarkets.ai — OKX.AI A2MCP ASP — environment ─────────────────────────────
# Copy to .env and fill in.  .env is gitignored; NEVER commit real keys.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Public https base URL the ASP is reachable at (behind your reverse proxy / TLS).
PUBLIC_BASE_URL=https://your-vps.example.com

# ── QuestDB (self-hosted OSS, Apache 2.0) ─────────────────────────────────────
# PG-wire endpoint (default QuestDB port 8812). Run the container on a stable
# always-on host, NOT the presentation laptop.
QUESTDB_HOST=127.0.0.1
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

# Where this server's attestations claim their data came from (for the payload).
DATA_SOURCE=okx

# ── Proof signing (verification tier) ─────────────────────────────────────────
# ed25519 server keypair, hex-encoded. Generate with: pnpm gen-key
# Publish PROOF_PUBLIC_KEY so any third party can verify attestations offline.
PROOF_PRIVATE_KEY=
PROOF_PUBLIC_KEY=

# ── OKX.AI x402 / X Layer payment (CONFIRMED from OKX A2MCP guide) ─────────────
# The OKX Payment SDK (@okxweb3/x402-*) handles the 402 challenge, EIP-3009
# verification, and X Layer settlement — you don't hold RPC/keys for settlement.
#
# payTo = your OKX Agentic Wallet 0x address. You get it in the registration flow:
#   1) install the agent skill:  npx skills add okx/onchainos-skills --yes -g
#   2) prompt your agent:        "Log in to Agentic Wallet on Onchain OS with my email"
# Then paste the provisioned 0x address here:
X402_PAY_TO=0xYOUR_OKX_AGENTIC_WALLET_ADDRESS
# X Layer mainnet (CAIP-2). 196 = X Layer:
X402_NETWORK=eip155:196
# Official settlement stablecoin on X Layer = USDT0 (USD₮0), decimals=6.
# (amounts are min units: 10000 = 0.01). This is the confirmed contract:
X402_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
