# ── IoMarkets.ai — OKX.AI A2MCP ASP — environment ─────────────────────────────
# Copy to .env and fill in.  .env is gitignored; NEVER commit real keys.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Public https base URL the ASP is reachable at (behind your reverse proxy / TLS).
PUBLIC_BASE_URL=https://your-vps.example.com

# ── QuestDB (self-hosted OSS, Apache 2.0) ─────────────────────────────────────
# PG-wire endpoint (default QuestDB port 8812). Run the container on a stable
# always-on host, NOT the presentation laptop.
QUESTDB_HOST=127.0.0.1
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

# Where this server's attestations claim their data came from (for the payload).
DATA_SOURCE=okx

# ── Proof signing (verification tier) ─────────────────────────────────────────
# ed25519 server keypair, hex-encoded. Generate with: pnpm gen-key
# Publish PROOF_PUBLIC_KEY so any third party can verify attestations offline.
PROOF_PRIVATE_KEY=
PROOF_PUBLIC_KEY=

# ── OKX.AI x402 / X Layer payment ─────────────────────────────────────────────
# Wired via the OKX Payment SDK (@okxweb3/x402-express). The SDK builds the 402
# challenge, verifies the EIP-3009 payment, and settles USDT0 on X Layer through
# the OKX facilitator. If any of the 4 vars below are unset, priced routes serve
# FREE (local dev). When all set, they require payment.
#
# payTo = your OKX Agentic Wallet 0x address. Provisioned in the registration flow:
#   1) install the agent skill:  npx skills add okx/onchainos-skills --yes -g
#   2) prompt your agent:        "Log in to Agentic Wallet on Onchain OS with my email"
X402_PAY_TO=0xYOUR_OKX_AGENTIC_WALLET_ADDRESS
# X Layer (CAIP-2): mainnet = eip155:196, testnet = eip155:1952 (test first!).
X402_NETWORK=eip155:196
# OKX facilitator credentials — apply at the OKX Developer Portal:
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# FYI (SDK handles it): settlement stablecoin on X Layer = USDT0
# 0x779ded0c9e1022225f8e0630b35a9b54be713736 (decimals 6). Prices are USD strings
# (config.prices) — the SDK converts to USDT0, so no per-network price changes.
# Testnet faucet (test OKB gas + test USDT0): the X Layer Faucet.
