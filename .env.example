# ── IoMarkets.ai — OKX.AI A2MCP ASP — environment ─────────────────────────────
# Copy to .env and fill in.  .env is gitignored; NEVER commit real keys.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Public https base URL the ASP is reachable at (behind your reverse proxy / TLS).
PUBLIC_BASE_URL=https://your-vps.example.com

# ── QuestDB (self-hosted OSS, Apache 2.0) ─────────────────────────────────────
# PG-wire endpoint (default QuestDB port 8812). Run the container on a stable
# always-on host, NOT the presentation laptop.
QUESTDB_HOST=127.0.0.1
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

# Where this server's attestations claim their data came from (for the payload).
DATA_SOURCE=okx

# ── Proof signing (verification tier) ─────────────────────────────────────────
# ed25519 server keypair, hex-encoded. Generate with: pnpm gen-key
# Publish PROOF_PUBLIC_KEY so any third party can verify attestations offline.
PROOF_PRIVATE_KEY=
PROOF_PUBLIC_KEY=

# ── OKX.AI x402 / X Layer payment  (CONFIRM these 3 from OKX onboarding) ───────
# You do NOT put a private key here — OKX's Broker/facilitator handles all
# on-chain interaction (RPC, gas, settlement). These values only DESCRIBE the
# paywall so the reverse-proxy broker (Path A) or in-process SDK (Path B) can
# advertise correct x402 payment requirements.
#
# 1) The OKX Agentic Wallet 0x address that receives payments:
X402_PAY_TO=0xYOUR_OKX_AGENTIC_WALLET_ADDRESS
# 2) X Layer network id (CAIP-2). Mainnet = eip155:196, testnet = eip155:195:
X402_NETWORK=eip155:196
# 3) USDC (or USDT) token contract on X Layer — get from OKX seller docs:
X402_ASSET=0xUSDC_CONTRACT_ON_X_LAYER
# OKX OnchainOS broker / facilitator endpoint (get from OKX seller onboarding):
X402_FACILITATOR_URL=https://CONFIRM_FROM_OKX
